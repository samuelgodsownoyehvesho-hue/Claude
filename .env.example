# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required for Groq Whisper transcription API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# -----------------------------------------------------------------------------
# Supabase (Auth + Database) — replaces the old Firebase configuration.
# Create a project at https://supabase.com, then find these under
# Project Settings > API. They must be prefixed with VITE_ so the
# client-side bundle can read them via import.meta.env.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Google and Spotify sign-in are configured entirely inside the Supabase
# dashboard (Authentication > Providers) — no client secrets are needed here.
# See supabase-schema.sql for the required Postgres tables + RLS policies,
# and README.md for the full provider setup steps.

# Optional Spotify API integration for searching songs and auto-filling
# metadata/cover art inside the editor (separate from Spotify *login*, which
# is handled by Supabase). If left blank, this falls back to public/demo
# client credentials with limited quota.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
